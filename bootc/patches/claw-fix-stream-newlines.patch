+/// Strip `<think>…</think>` blocks that thinking models (e.g. Qwen3) emit
+/// as raw SSE content. Because the block may span multiple streaming deltas,
+/// `in_think` carries the state between calls.
+fn filter_think_content(text: &str, in_think: &mut bool) -> String {
+    let mut output = String::new();
+    let mut s = text;
+    loop {
+        if *in_think {
+            if let Some(pos) = s.find("</think>") {
+                *in_think = false;
+                s = &s[pos + "</think>".len()..];
+                s = s.trim_start_matches('\n');
+            } else {
+                break;
+            }
+        } else if let Some(pos) = s.find("<think>") {
+            output.push_str(&s[..pos]);
+            *in_think = true;
+            s = &s[pos + "<think>".len()..];
+            s = s.trim_start_matches('\n');
+        } else {
+            output.push_str(s);
+            break;
+        }
