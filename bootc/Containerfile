# ── Version pins ──────────────────────────────────────────────────────────────
# All image references and commit hashes are defined here as ARGs so they can
# be overridden at build time with --build-arg without editing the Containerfile.
ARG FEDORA_BOOTC_IMAGE=quay.io/fedora/fedora-bootc
ARG FEDORA_BOOTC_REF=latest
# One agent per image, no runtime switching. Valid AGENT_KIND: opencode,
# claw, claude. opencode is the default and recommended runtime. claw-code
# is experimental — its MCP client needs the mcp-proxy bridge and a local
# patch (see bootc/patches/claw-fix-mcp-stdio-framing.patch). claude is the
# upstream Anthropic Claude Code native binary and speaks only the Anthropic
# protocol (no local OpenAI-compatible backends — see docs/model-providers.md).
ARG AGENT_KIND=opencode
ARG CLAW_CODE_REPO=https://github.com/ultraworkers/claw-code.git
ARG CLAW_CODE_REF=f8e1bb7262b261da1ee6bfcd461bfc5b676f6a6d
# Expected SHA-256 of the built claw-code binary. Empty = record only
# (first build, or after a Fedora rustc toolchain bump). Non-empty = enforce:
# any drift (Cargo.lock change, patch tamper, toolchain compromise) fails the
# build before the bootc image is produced. See docs/build.md for the workflow.
# Arch-specific: this hash is for linux/amd64 with the pinned CLAW_CODE_REF
# and the patches in bootc/patches/, built on the rust toolchain shipped in
# the current FEDORA_BOOTC_REF base — check the build summary for the exact
# rustc version. arm64 builds produce a different hash; override with
# --build-arg when building for arm64.
ARG CLAW_CODE_SHA256=
# opencode ships pre-built single-binaries upstream; we download and verify
# rather than compile. Trust surface == service-gator (digest-pinned).
ARG OPENCODE_RELEASE_BASE=https://github.com/anomalyco/opencode/releases/download
ARG OPENCODE_REF=v1.15.4
ARG OPENCODE_ASSET=opencode-linux-x64.tar.gz
# SHA-256 of the upstream tarball for linux/amd64. Empty = record only.
# arm64 build requires OPENCODE_ASSET=opencode-linux-arm64.tar.gz and
# a different SHA — override both with --build-arg.
ARG OPENCODE_SHA256=f0734928d5df360777f51f807df18b28c1d0c006f806ad0bd35a2420fabd0835
# Claude Code: native single-file binaries from downloads.claude.ai. With the
# version pinned, the download URL is fully determined — no script is run.
# Trust surface == opencode, plus GPG verification of the signed manifest.
ARG CLAUDE_CODE_RELEASE_BASE=https://downloads.claude.ai/claude-code-releases
# Exact version. Must be >= 2.1.89 — releases from there on ship a signed
# manifest. Directly addressable as {BASE}/{REF}/... — no channel resolution.
ARG CLAUDE_CODE_REF=2.1.140
# linux-x64 is the glibc build, correct for the Fedora clawx-runtime
# (linux-x64-musl would be wrong).
ARG CLAUDE_CODE_PLATFORM=linux-x64
# SHA-256 of the upstream linux-x64 binary, taken from the GPG-verified
# manifest for CLAUDE_CODE_REF. Empty = record only. arm64 needs
# CLAUDE_CODE_PLATFORM=linux-arm64 and a different SHA — override both.
ARG CLAUDE_CODE_SHA256=807a5d6ca063f5e03e4b7283934036a3122723b28c28e1a6978e98cf2d43d0b5
# Pinned to a digest so a tag move cannot silently change the running image.
# Upstream moved to LobsterTrap/service-gator; the cgwalters namespace is no
# longer rebuilt. Track LobsterTrap going forward.
ARG SERVICE_GATOR_IMAGE=ghcr.io/lobstertrap/service-gator
ARG SERVICE_GATOR_REF=sha256:792dd2cc83d94b4748a9b4d216f3f6dd2895d05adc17bf16a4a249e8ce43d232
# Web-search stack. SearXNG is pulled from ghcr.io (same digest as
# docker.io/searxng/searxng, no Docker-Hub-Cloudflare-CDN involvement, ghcr
# is already in the egress allowlist). mcp-searxng is installed as an npm
# package into the clawx-runtime image (see bootc/clawx-runtime/Containerfile)
# and runs from there — no separate OCI image needed.
ARG SEARXNG_IMAGE=ghcr.io/searxng/searxng
ARG SEARXNG_REF=sha256:25ff3c045548971d12726e54bea4564b8ec3bedb3d6951aecdefd01caf840974
# docs-mcp-server: opt-in docs lookup MCP. Same digest-pin pattern as
# service-gator and SearXNG. Adopted per audits/docs-mcp-server-2026-05-19.md;
# telemetry kill-switch is wired in the Quadlet env, not here.
ARG DOCS_MCP_IMAGE=ghcr.io/arabold/docs-mcp-server
ARG DOCS_MCP_REF=sha256:a00a30040bac410678c175dcf8b60f5fed6357cf761bcc5a63ab56383ae3e8a9
# mcp-llm-wiki: opt-in git-backed LLM-wiki MCP. Built from the separate
# mcp-llm-wiki repo and published to the Gitea registry. Same digest-pin
# pattern as the MCPs above. Always operator-enabled (no [Install]) —
# it needs Gitea service-account + token setup first; see
# docs/llm-wiki.md and audits/llm-wiki-server-2026-05-20.md.
ARG MCP_LLM_WIKI_IMAGE=ghcr.io/np6126/mcp-llm-wiki
ARG MCP_LLM_WIKI_REF=sha256:e7756e6028ec08c88455d02c3cda16a1b85cf221ae6b0f5b1e00e8030ce693c2
# Build-time opt-in for agent persistent memory. Default OFF: agent memory
# writes go to the container's ephemeral overlay-FS and are lost on
# container recreate. Set to "true" at image build to symlink the agent's
# memory directory into ~/.clawx/, surviving container restarts.
# Trade-off: prompt-injection content the agent reads during one session
# can survive into the next session as "remembered notes" — see
# docs/memory.md. CLAUDE.md instructs the agent to treat such notes as
# data rather than authoritative commands, but the operator should
# enable this consciously.
ARG AGENT_MEMORY_PERSIST=false
# clawx runtime container — build bootc/clawx-runtime/Containerfile and push
# before updating this reference. Tag only (not digest); bump together with
# FEDORA_BOOTC_REF when doing a Fedora release upgrade.
ARG CLAWX_RUNTIME_IMAGE=ghcr.io/np6126/clawx-runtime
ARG CLAWX_RUNTIME_REF=44
# ──────────────────────────────────────────────────────────────────────────────

FROM ${FEDORA_BOOTC_IMAGE}:${FEDORA_BOOTC_REF} AS claw-builder

# Re-declare so the build stage inherits the values.
ARG CLAW_CODE_REPO
ARG CLAW_CODE_REF
ARG CLAW_CODE_SHA256
ENV CARGO_HOME=/var/tmp/cargo
# Reproducibility flags: --remap-path-prefix strips absolute build paths
# (/opt/claw-code, CARGO_HOME) from the binary's debug info and panic
# messages. -C strip=symbols removes debug symbol tables that would otherwise
# vary between builds. `cargo build` runs without --locked because our sed
# above flips reqwest from rustls-tls to rustls-tls-native-roots, which pulls
# rustls-native-certs into the dep graph and forces Cargo.lock to expand.
# The CLAW_CODE_SHA256 pin on the resulting binary is what enforces
# reproducibility — any silent dep drift changes the hash and fails the build.
# A Fedora rustc upgrade also produces a new hash and requires re-recording
# CLAW_CODE_SHA256 — that is intentional.
ENV RUSTFLAGS="--remap-path-prefix=/opt/claw-code=. --remap-path-prefix=/var/tmp/cargo=cargo -C strip=symbols"

COPY patches/ /build/patches/

RUN set -eux; \
    dnf -y install \
      cargo \
      gcc \
      git \
      make \
      openssl-devel \
      pkgconf-pkg-config \
      rust; \
    install -d -m 0755 "${CARGO_HOME}"; \
    git clone "${CLAW_CODE_REPO}" /opt/claw-code; \
    cd /opt/claw-code; \
    git checkout "${CLAW_CODE_REF}"; \
    git apply /build/patches/claw-fix-stream-newlines.patch; \
    git apply /build/patches/claw-add-think-block-filter.patch; \
    git apply /build/patches/claw-fix-openai-prefix-strip.patch; \
    git apply /build/patches/claw-fix-mcp-stdio-framing.patch; \
    git apply /build/patches/claw-lock-project-config.patch; \
    cd rust; \
    grep -q '"rustls-tls"' crates/api/Cargo.toml; \
    sed -i 's/features = \["json", "rustls-tls"\]/features = ["json", "rustls-tls-native-roots"]/' crates/api/Cargo.toml; \
    cargo build --workspace --release; \
    install -D -m 0755 target/release/claw /usr/local/bin/agent; \
    actual_sha=$(sha256sum /usr/local/bin/agent | awk '{print $1}'); \
    rustc_version=$(rustc --version); \
    install -d -m 0755 /usr/local/share/tank-os; \
    printf '%s  /usr/local/bin/agent\n' "${actual_sha}" \
      > /usr/local/share/tank-os/agent.sha256; \
    chmod 0644 /usr/local/share/tank-os/agent.sha256; \
    printf '\nagent build summary (claw-code):\n'; \
    printf '  rustc:    %s\n' "${rustc_version}"; \
    printf '  source:   %s @ %s\n' "${CLAW_CODE_REPO}" "${CLAW_CODE_REF}"; \
    printf '  sha256:   %s\n' "${actual_sha}"; \
    if [ -n "${CLAW_CODE_SHA256}" ]; then \
      if [ "${actual_sha}" != "${CLAW_CODE_SHA256}" ]; then \
        printf '\nERROR: claw-code binary SHA-256 mismatch.\n' >&2; \
        printf '  expected: %s\n' "${CLAW_CODE_SHA256}" >&2; \
        printf '  actual:   %s\n' "${actual_sha}" >&2; \
        printf '\nSee docs/build.md for the hash-pinning workflow.\n' >&2; \
        exit 1; \
      fi; \
      printf '  status:   verified against pinned CLAW_CODE_SHA256\n'; \
    else \
      printf '  status:   recorded only (CLAW_CODE_SHA256 not set)\n'; \
    fi

FROM ${FEDORA_BOOTC_IMAGE}:${FEDORA_BOOTC_REF} AS opencode-builder

ARG OPENCODE_RELEASE_BASE
ARG OPENCODE_REF
ARG OPENCODE_ASSET
ARG OPENCODE_SHA256

RUN set -eux; \
    asset_url="${OPENCODE_RELEASE_BASE}/${OPENCODE_REF}/${OPENCODE_ASSET}"; \
    curl -fsSL -o /tmp/opencode.tar.gz "${asset_url}"; \
    actual_sha=$(sha256sum /tmp/opencode.tar.gz | awk '{print $1}'); \
    install -d -m 0755 /usr/local/share/tank-os /usr/local/bin; \
    printf '\nagent build summary (opencode):\n'; \
    printf '  source:   %s @ %s\n' "${OPENCODE_RELEASE_BASE}" "${OPENCODE_REF}"; \
    printf '  asset:    %s\n' "${OPENCODE_ASSET}"; \
    printf '  sha256:   %s  (tarball)\n' "${actual_sha}"; \
    if [ -n "${OPENCODE_SHA256}" ]; then \
      if [ "${actual_sha}" != "${OPENCODE_SHA256}" ]; then \
        printf '\nERROR: opencode tarball SHA-256 mismatch.\n' >&2; \
        printf '  expected: %s\n' "${OPENCODE_SHA256}" >&2; \
        printf '  actual:   %s\n' "${actual_sha}" >&2; \
        printf '\nSee docs/build.md for the hash-pinning workflow.\n' >&2; \
        exit 1; \
      fi; \
      printf '  status:   verified against pinned OPENCODE_SHA256\n'; \
    else \
      printf '  status:   recorded only (OPENCODE_SHA256 not set)\n'; \
    fi; \
    tar -xzf /tmp/opencode.tar.gz -C /usr/local/bin opencode; \
    mv /usr/local/bin/opencode /usr/local/bin/agent; \
    chmod 0755 /usr/local/bin/agent; \
    binary_sha=$(sha256sum /usr/local/bin/agent | awk '{print $1}'); \
    printf '%s  /usr/local/bin/agent\n' "${binary_sha}" \
      > /usr/local/share/tank-os/agent.sha256; \
    chmod 0644 /usr/local/share/tank-os/agent.sha256; \
    printf '  binary:   %s\n' "${binary_sha}"; \
    rm -f /tmp/opencode.tar.gz

FROM ${FEDORA_BOOTC_IMAGE}:${FEDORA_BOOTC_REF} AS claude-builder

ARG CLAUDE_CODE_RELEASE_BASE
ARG CLAUDE_CODE_REF
ARG CLAUDE_CODE_PLATFORM
ARG CLAUDE_CODE_SHA256

# Anthropic's Claude Code release-signing key, checked into the repo as the
# trust anchor — the build verifies the signed manifest against it, so no key
# is fetched at build time. The fingerprint is hard-checked below; a swapped
# key file fails the build.
COPY keys/ /build/keys/

# Native single-file binary: download, GPG-verify the signed manifest, then
# verify the binary against both the manifest checksum and the in-repo pin.
# No tar — the distribution ships a raw binary. gnupg2 + python3 are builder-
# only (this stage is discarded; they never reach the bootc image).
RUN set -eux; \
    dnf -y install gnupg2 python3; \
    export GNUPGHOME=/tmp/claude-gpg; \
    install -d -m 0700 "${GNUPGHOME}"; \
    gpg --quiet --import /build/keys/claude-code-release.asc; \
    fpr=$(gpg --with-colons --fingerprint \
            "Anthropic Claude Code Release Signing" \
          | awk -F: '/^fpr:/ {print $10; exit}'); \
    expected_fpr=31DDDE24DDFAB679F42D7BD2BAA929FF1A7ECACE; \
    if [ "${fpr}" != "${expected_fpr}" ]; then \
      printf '\nERROR: Claude Code signing-key fingerprint mismatch.\n' >&2; \
      printf '  expected: %s\n' "${expected_fpr}" >&2; \
      printf '  actual:   %s\n' "${fpr}" >&2; \
      exit 1; \
    fi; \
    rel="${CLAUDE_CODE_RELEASE_BASE}/${CLAUDE_CODE_REF}"; \
    curl -fsSL -o /tmp/manifest.json     "${rel}/manifest.json"; \
    curl -fsSL -o /tmp/manifest.json.sig "${rel}/manifest.json.sig"; \
    # Verify the manifest signature before fetching the large binary, so a
    # bad signature fails the build without paying the download.
    gpg --batch --verify /tmp/manifest.json.sig /tmp/manifest.json; \
    curl -fsSL -o /tmp/claude            "${rel}/${CLAUDE_CODE_PLATFORM}/claude"; \
    manifest_sha=$(python3 -c \
      'import json,sys; print(json.load(open("/tmp/manifest.json"))["platforms"][sys.argv[1]]["checksum"])' \
      "${CLAUDE_CODE_PLATFORM}"); \
    actual_sha=$(sha256sum /tmp/claude | awk '{print $1}'); \
    install -d -m 0755 /usr/local/share/tank-os; \
    printf '\nagent build summary (claude-code):\n'; \
    printf '  source:   %s @ %s\n' "${CLAUDE_CODE_RELEASE_BASE}" "${CLAUDE_CODE_REF}"; \
    printf '  platform: %s\n' "${CLAUDE_CODE_PLATFORM}"; \
    printf '  manifest: GPG signature verified (Anthropic Claude Code Release Signing)\n'; \
    printf '  sha256:   %s  (binary)\n' "${actual_sha}"; \
    if [ "${actual_sha}" != "${manifest_sha}" ]; then \
      printf '\nERROR: Claude Code binary does not match the signed manifest checksum.\n' >&2; \
      printf '  manifest: %s\n' "${manifest_sha}" >&2; \
      printf '  actual:   %s\n' "${actual_sha}" >&2; \
      exit 1; \
    fi; \
    printf '  status:   matches GPG-verified manifest checksum\n'; \
    if [ -n "${CLAUDE_CODE_SHA256}" ]; then \
      if [ "${actual_sha}" != "${CLAUDE_CODE_SHA256}" ]; then \
        printf '\nERROR: Claude Code binary SHA-256 mismatch.\n' >&2; \
        printf '  expected: %s\n' "${CLAUDE_CODE_SHA256}" >&2; \
        printf '  actual:   %s\n' "${actual_sha}" >&2; \
        printf '\nSee docs/build.md for the hash-pinning workflow.\n' >&2; \
        exit 1; \
      fi; \
      printf '  status:   verified against pinned CLAUDE_CODE_SHA256\n'; \
    else \
      printf '  status:   recorded only (CLAUDE_CODE_SHA256 not set)\n'; \
    fi; \
    install -D -m 0755 /tmp/claude /usr/local/bin/agent; \
    printf '%s  /usr/local/bin/agent\n' "${actual_sha}" \
      > /usr/local/share/tank-os/agent.sha256; \
    chmod 0644 /usr/local/share/tank-os/agent.sha256; \
    rm -rf /tmp/claude /tmp/manifest.json /tmp/manifest.json.sig "${GNUPGHOME}"

FROM ${FEDORA_BOOTC_IMAGE}:${FEDORA_BOOTC_REF}

# Re-declare so this stage inherits the values from the top-level ARG block.
ARG AGENT_KIND
ARG SERVICE_GATOR_IMAGE
ARG SERVICE_GATOR_REF
ARG SEARXNG_IMAGE
ARG SEARXNG_REF
ARG DOCS_MCP_IMAGE
ARG DOCS_MCP_REF
ARG MCP_LLM_WIKI_IMAGE
ARG MCP_LLM_WIKI_REF
ARG AGENT_MEMORY_PERSIST
ARG CLAWX_RUNTIME_IMAGE
ARG CLAWX_RUNTIME_REF

LABEL containers.bootc=1 \
  org.opencontainers.image.title="tank-agent-os" \
  org.opencontainers.image.description="Fedora bootc image for an AI coding agent on the tank-os rootless Podman architecture" \
  org.opencontainers.image.source="https://github.com/np6126/tank-agent-os.git"

ARG CLAWX_UID=1000
ARG CLAWX_GID=1000
ARG CLAWX_SUBID_START=100000
ARG CLAWX_SUBID_COUNT=65536

RUN set -eux; \
    dnf -y install \
      cloud-init \
      nftables \
      nss-tools \
      openssh-server \
      podman \
      python3 \
      qemu-guest-agent \
      shadow-utils \
      sudo \
      tar \
      unzip \
      vim-enhanced; \
    dnf clean all; \
    rm -rf /var/cache/dnf /var/log/dnf*; \
    getent group clawx >/dev/null || groupadd -g "${CLAWX_GID}" clawx; \
    id -u clawx >/dev/null 2>&1 || \
      useradd -u "${CLAWX_UID}" -g "${CLAWX_GID}" -m -d /var/home/clawx -s /bin/bash clawx; \
    grep -q '^clawx:' /etc/subuid 2>/dev/null || \
      printf 'clawx:%s:%s\n' "${CLAWX_SUBID_START}" "${CLAWX_SUBID_COUNT}" >> /etc/subuid; \
    grep -q '^clawx:' /etc/subgid 2>/dev/null || \
      printf 'clawx:%s:%s\n' "${CLAWX_SUBID_START}" "${CLAWX_SUBID_COUNT}" >> /etc/subgid; \
    install -d -m 0700 -o clawx -g clawx /var/home/clawx/.clawx; \
    install -d -m 0700 -o clawx -g clawx /var/home/clawx/workspaces; \
    install -d -m 0755 /etc/clawx; \
    install -d -m 0755 /var/lib/systemd/linger; \
    touch /var/lib/systemd/linger/clawx

COPY rootfs/ /
# ARG expansion in --from= is broken on older Buildah/Podman versions, so we
# COPY all three builder outputs and let a RUN step pick the one matching AGENT_KIND.
COPY --from=claw-builder     /usr/local/bin/agent                /opt/agent-candidates/claw
COPY --from=claw-builder     /usr/local/share/tank-os/agent.sha256 /opt/agent-candidates/claw.sha256
COPY --from=opencode-builder /usr/local/bin/agent                /opt/agent-candidates/opencode
COPY --from=opencode-builder /usr/local/share/tank-os/agent.sha256 /opt/agent-candidates/opencode.sha256
COPY --from=claude-builder   /usr/local/bin/agent                /opt/agent-candidates/claude
COPY --from=claude-builder   /usr/local/share/tank-os/agent.sha256 /opt/agent-candidates/claude.sha256

RUN set -eux; \
    case "${AGENT_KIND}" in claw|opencode|claude) ;; *) \
      echo "Unsupported AGENT_KIND: ${AGENT_KIND}" >&2; exit 2 ;; esac; \
    install -D -m 0755 "/opt/agent-candidates/${AGENT_KIND}" /usr/local/bin/agent; \
    install -D -m 0644 "/opt/agent-candidates/${AGENT_KIND}.sha256" \
      /usr/local/share/tank-os/agent.sha256; \
    rm -rf /opt/agent-candidates; \
    printf '%s\n' "${AGENT_KIND}" > /etc/clawx/agent.kind; \
    chmod 0644 /etc/clawx/agent.kind; \
    # opencode and claude come with web search wired in — auto-enable the
    # SearXNG + docs-mcp stack so it works out of the box. claw images keep
    # the Quadlets but leave them unenabled (operator's choice).
    case "${AGENT_KIND}" in opencode|claude) \
      printf '\n[Install]\nWantedBy=default.target\n' \
        >> /etc/containers/systemd/users/1000/searxng.container; \
      printf '\n[Install]\nWantedBy=default.target\n' \
        >> /etc/containers/systemd/users/1000/mcp-searxng.container; \
      printf '\n[Install]\nWantedBy=default.target\n' \
        >> /etc/containers/systemd/users/1000/docs-mcp.container ;; \
    claw) \
      # Strip the not-auto-started opt-in MCP entries from claw-settings.json
      # on claw images. claw-code spawns one mcp-proxy stdio bridge per entry
      # at agent startup and blocks the first prompt until each bridge has
      # completed its streamable-HTTP handshake; an entry whose backend
      # container is not running stalls the bridge (DNS NXDOMAIN inside
      # clawx-isolated.network -> repeated retries inside mcp-proxy)
      # for minutes. Operators who enable mcp-searxng or docs-mcp manually
      # must add the matching entries back; the entries in the rootfs/
      # template are the documented form.
      python3 -c '\
import json, sys; \
p = "/etc/clawx/claw-settings.json"; \
c = json.load(open(p)); \
[c["mcpServers"].pop(k, None) for k in ("docs-mcp", "searxng")]; \
open(p, "w").write(json.dumps(c, indent=2) + "\n")' ;; \
    esac

# Substitute version-pin ARGs into the Quadlet unit files that were just copied
# from rootfs/. The rootfs/ copies carry placeholder values; the ARG defaults at
# the top of this file are the single source of truth for the actual pins.
RUN set -eux; \
    sed -i \
      "s|^Image=ghcr.io/cgwalters/service-gator.*|Image=${SERVICE_GATOR_IMAGE}@${SERVICE_GATOR_REF}|" \
      /etc/containers/systemd/users/1000/service-gator.container; \
    sed -i \
      "s|^Image=quay.io/fedora/fedora:placeholder$|Image=${CLAWX_RUNTIME_IMAGE}:${CLAWX_RUNTIME_REF}|" \
      /etc/containers/systemd/users/1000/clawx.container; \
    sed -i \
      "s|^Image=docker.io/searxng/searxng:placeholder$|Image=${SEARXNG_IMAGE}@${SEARXNG_REF}|" \
      /etc/containers/systemd/users/1000/searxng.container; \
    sed -i \
      "s|^Image=quay.io/fedora/fedora:mcp-searxng-placeholder$|Image=${CLAWX_RUNTIME_IMAGE}:${CLAWX_RUNTIME_REF}|" \
      /etc/containers/systemd/users/1000/mcp-searxng.container; \
    sed -i \
      "s|^Image=ghcr.io/arabold/docs-mcp-server:placeholder$|Image=${DOCS_MCP_IMAGE}@${DOCS_MCP_REF}|" \
      /etc/containers/systemd/users/1000/docs-mcp.container; \
    sed -i \
      "s|^Image=localhost/mcp-llm-wiki:placeholder$|Image=${MCP_LLM_WIKI_IMAGE}@${MCP_LLM_WIKI_REF}|" \
      /etc/containers/systemd/users/1000/llm-wiki.container; \
    sed -i \
      "s|^Environment=AGENT_MEMORY_PERSIST=__placeholder__$|Environment=AGENT_MEMORY_PERSIST=${AGENT_MEMORY_PERSIST}|" \
      /etc/containers/systemd/users/1000/clawx.container

RUN set -eux; \
    chmod 0755 \
      /usr/local/bin/agent \
      /usr/local/bin/clawx \
      /usr/local/bin/tank-os-version \
      /usr/local/bin/tank-clawx-secrets \
      /usr/libexec/tank-os/bootstrap-clawx \
      /usr/libexec/tank-os/bootstrap-docs-mcp-nssdb \
      /usr/libexec/tank-os/bootstrap-service-gator \
      /usr/libexec/tank-os/gen-opencode-config \
      /usr/libexec/tank-os/gen-searxng-settings \
      /usr/libexec/tank-os/provision-toolchains \
      /usr/libexec/tank-os/setup-clawx-nftables \
      /usr/libexec/tank-os/sync-podman-secrets; \
    # Bake opencode-config.json from gen-opencode-config so the shipped file
    # cannot drift from the generator (which also re-runs at every boot).
    /usr/libexec/tank-os/gen-opencode-config --print > /etc/clawx/opencode-config.json; \
    chmod 0644 \
      /usr/share/tank-os/agent-config.env.example \
      /usr/share/tank-os/scopes.json.example \
      /usr/share/tank-os/toolchains.conf.example \
      /etc/clawx/CLAUDE.md \
      /etc/clawx/opencode-config.json \
      /etc/clawx/claw-settings.json \
      /etc/clawx/claude-mcp.json \
      /etc/clawx/claude-managed-settings.json \
      /etc/clawx/searxng-settings.yml.template; \
    chmod 0440 /etc/sudoers.d/clawx; \
    chown -R clawx:clawx /var/home/clawx; \
    systemctl enable sshd.service nftables.service clawx-nftables.service qemu-guest-agent.service clawx-opencode-config.path clawx-opencode-config.service clawx-searxng-settings.service; \
    systemctl mask NetworkManager-wait-online.service; \
    for unit in \
      cloud-init-local.service \
      cloud-init-network.service \
      cloud-config.service \
      cloud-final.service; \
    do \
      if [ -e "/usr/lib/systemd/system/${unit}" ] || [ -e "/etc/systemd/system/${unit}" ]; then \
        systemctl enable "${unit}"; \
      fi; \
    done
