ARG FEDORA_CONTAINER_IMAGE=quay.io/fedora/fedora
ARG FEDORA_CONTAINER_REF=44
# UID/GID of the in-container agent user. Must match the bootc image's
# CLAWX_UID/CLAWX_GID (bootc/Containerfile) and the user-1000 Quadlet
# directory layout — `users/1000/clawx.container` ships User=%U:%G plus
# UserNS=keep-id, both of which assume 1000.
ARG CLAWX_UID=1000
ARG CLAWX_GID=1000

FROM ${FEDORA_CONTAINER_IMAGE}:${FEDORA_CONTAINER_REF}

# Toolchain path convention. The JDK / Android SDK / Gradle / Kotlin are NOT
# baked into this image — they are operator-provisioned into the agent's
# writable ~/.clawx mount by /usr/libexec/tank-os/provision-toolchains (see
# docs/provisioning.md). These vars point at that convention and are inert
# until it is populated.
ENV JAVA_HOME=/home/clawx/.clawx/toolchains/jdk
ENV ANDROID_HOME=/home/clawx/.clawx/toolchains/android-sdk
ENV GRADLE_USER_HOME=/home/clawx/.clawx/gradle
ENV PATH="${PATH}:${JAVA_HOME}/bin:${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:/home/clawx/.clawx/toolchains/gradle/bin:/home/clawx/.clawx/toolchains/kotlinc/bin"

RUN set -eux; \
    dnf -y install \
      curl \
      diffutils \
      findutils \
      gcc \
      gcc-c++ \
      git \
      htop \
      iproute \
      jq \
      less \
      lsof \
      make \
      nodejs \
      npm \
      openssl \
      procps-ng \
      python3 \
      python3-pip \
      ripgrep \
      rsync \
      tree \
      unzip \
      util-linux \
      vim-minimal \
      yq \
      zip; \
    dnf clean all; \
    rm -rf /var/cache/dnf /var/log/dnf*

# mcp-searxng MCP server (used by opencode for web search). Installed from
# the public npm registry with --ignore-scripts to block post-install code
# execution from any dependency. The mcp-searxng.container Quadlet runs this
# binary in its own container; it does not share env with the agent (no API
# keys), matching the trust-class pattern of service-gator.
ARG MCP_SEARXNG_VERSION=1.0.3
RUN npm install -g --ignore-scripts "mcp-searxng@${MCP_SEARXNG_VERSION}"

# mcp-proxy: a stdio<->streamable-HTTP MCP bridge. claw-code's MCP client
# (McpServerManager) supports only the stdio transport — it cannot reach the
# HTTP MCP servers on the clawx-isolated bridge directly. claw-code therefore
# spawns `mcp-proxy <url>` as a stdio subprocess (see the mcpServers block in
# /etc/clawx/claw-settings.json, shipped by the bootc image); mcp-proxy
# connects to the HTTP endpoint and bridges it to stdio. opencode speaks
# streamable-HTTP natively and does not use this.
#
# Installed into its own venv — Fedora's system python is PEP-668
# externally-managed. Dependencies are hash-pinned via --require-hashes
# (mcp-proxy-requirements.txt, regenerated with pip-compile --generate-hashes).
COPY mcp-proxy-requirements.txt /tmp/mcp-proxy-requirements.txt
RUN python3 -m venv /opt/mcp-proxy; \
    /opt/mcp-proxy/bin/pip install --no-cache-dir --require-hashes \
      -r /tmp/mcp-proxy-requirements.txt; \
    ln -s /opt/mcp-proxy/bin/mcp-proxy /usr/local/bin/mcp-proxy; \
    rm /tmp/mcp-proxy-requirements.txt

# Pre-bake the @opencode-ai/plugin SDK that opencode tries to background-install
# from npm on every startup. Without this, opencode reaches out to
# registry.npmjs.org at runtime, fetches arbitrary JS, and tries to mkdir
# /home/clawx/.npm (outside the two writable mounts → EACCES + 60s retry hang).
# By dropping the resolved node_modules into the image read-only layer at build
# time, opencode finds the SDK already installed and skips the npm call entirely
# — keeps the runtime supply-chain closed.
#
# Pin: version is locked to OPENCODE_PLUGIN_VERSION (should match the opencode
# binary's InstallationVersion, which is OPENCODE_REF in bootc/Containerfile).
# The tarball SHA-256 is verified ourselves before letting npm pull transitive
# deps — npm's own integrity check covers the transitive tree (same trust model
# as mcp-searxng above).
ARG OPENCODE_PLUGIN_VERSION=1.15.4
ARG OPENCODE_PLUGIN_SHA256=c49dc5d3d6a887e90397b632d864560c0fb03dce2d55dd37e86d536ea5126e39
RUN set -eux; \
    BAKE_DIR=/usr/share/tank-os/opencode-plugin-bake; \
    mkdir -p "${BAKE_DIR}"; \
    curl -fsSL \
      "https://registry.npmjs.org/@opencode-ai/plugin/-/plugin-${OPENCODE_PLUGIN_VERSION}.tgz" \
      -o /tmp/plugin.tgz; \
    actual=$(sha256sum /tmp/plugin.tgz | awk '{print $1}'); \
    if [ "${actual}" != "${OPENCODE_PLUGIN_SHA256}" ]; then \
      printf '\nERROR: @opencode-ai/plugin sha256 mismatch.\n' >&2; \
      printf '  expected: %s\n' "${OPENCODE_PLUGIN_SHA256}" >&2; \
      printf '  actual:   %s\n' "${actual}" >&2; \
      exit 1; \
    fi; \
    cd "${BAKE_DIR}"; \
    printf '{"dependencies":{"@opencode-ai/plugin":"%s"}}\n' \
      "${OPENCODE_PLUGIN_VERSION}" > package.json; \
    npm install --ignore-scripts --no-audit --no-fund \
      --cache /tmp/npm-cache; \
    # Keep package-lock.json: opencode's Npm.install does a "dirty" check that
    # compares declared deps against lockfile entries. Missing lockfile → it
    # reifies via @npmcli/arborist → tries to write npm cache → mkdir
    # /home/clawx/.npm fails. With our lock in place, the check passes and
    # opencode skips the install path entirely (verified empirically).
    rm -rf /tmp/plugin.tgz /tmp/npm-cache

# /home/clawx must be writable by the in-container agent user so that
# clawx-init can create the ~/.claude/skills and ~/.claude/projects
# symlinks that bridge claw-code's lookup paths into the host-mounted
# ~/.clawx/ tree. The bind-mounts (~/.clawx, ~/workspaces) cover their own
# targets, but the parent /home/clawx remains image-FS — root-owned by
# default — and a `mkdir $HOME/.claude` in clawx-init would EACCES.
# The agent user is mapped into the container via `User=%U:%G` +
# `UserNS=keep-id` from the user-1000 Quadlet (clawx.container); the host
# clawx user has uid 1000, so CLAWX_UID/CLAWX_GID default to 1000.
# ARGs declared at the top of the file are only in scope for FROM; re-
# declare here so the values are available to this RUN's shell expansion.
ARG CLAWX_UID
ARG CLAWX_GID
RUN mkdir -p /home/clawx && chown ${CLAWX_UID}:${CLAWX_GID} /home/clawx

# clawx-init runs as PID 1 in the clawx container. It seeds the pre-baked
# plugin SDK on first start, then exec's sleep infinity. The container's
# Quadlet sets Exec=/usr/local/bin/clawx-init explicitly. See the script for
# the seeding logic and rationale.
# Mount points for the bootc image's root-owned claude-code config files.
# clawx.container bind-mounts claude-mcp.json and claude-managed-settings.json
# into these directories; declaring them keeps the parents root-owned with a
# known mode rather than relying on podman's implicit mount-point creation.
RUN mkdir -p /etc/clawx /etc/claude-code

COPY clawx-init /usr/local/bin/clawx-init
RUN chmod 0755 /usr/local/bin/clawx-init

# anthropic-strip-proxy: deletes the ?beta=true query string Claude Code
# appends to /v1/messages, which hangs an Ollama backend (claude-code issue
# #51239). clawx-init starts it at container boot; the clawx wrapper feeds it
# the backend URL and points claude at it. Stdlib-only Python — no venv, no
# pip deps, unlike mcp-proxy above.
COPY anthropic-strip-proxy /usr/local/bin/anthropic-strip-proxy
RUN chmod 0755 /usr/local/bin/anthropic-strip-proxy
