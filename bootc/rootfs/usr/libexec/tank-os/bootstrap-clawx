#!/usr/bin/env bash
set -euo pipefail

clawx_home="${HOME:-/var/home/clawx}/.clawx"
workspace_dir="${HOME:-/var/home/clawx}/workspaces"
# opencode's XDG_CONFIG_HOME mount target — pre-create as clawx so Podman's
# bind-mount setup doesn't materialise the parent as root and lock the
# agent out of writing siblings to opencode-config.json.
opencode_xdg_config="${HOME:-/var/home/clawx}/.clawx/xdg-config/opencode"

umask 077
mkdir -p "$clawx_home" "$workspace_dir" "$opencode_xdg_config"

# opencode 1.15+ does fs.access('$workspace/.git') at startup (including for
# `mcp list` and other non-git subcommands) and crashes with PermissionDenied
# if the path doesn't exist. The operator's real workflow will replace this
# placeholder when they `git clone` into ~/workspaces — but at first boot the
# directory is empty, so we lay down a minimal valid git repo skeleton.
git_marker="$workspace_dir/.git"
if [[ ! -e "$git_marker" ]]; then
    mkdir -p "$git_marker/refs/heads" "$git_marker/objects"
    printf 'ref: refs/heads/main\n' > "$git_marker/HEAD"
fi

# Build a merged CA bundle: system trust anchors + proxy CA cert.
# Compiled binaries (Go, Rust/openssl, etc.) read the system CA bundle path
# directly and are unaffected by NODE_EXTRA_CA_CERTS or SSL_CERT_FILE pointing
# to a proxy-cert-only file. Merging here ensures they also trust the MITM
# proxy certificate without losing trust in any real CA.
merged_bundle="$clawx_home/ca-bundle.crt"
if podman secret inspect proxy_ca_cert >/dev/null 2>&1; then
    proxy_ca=$(podman secret inspect proxy_ca_cert --showsecret --format '{{.SecretData}}' 2>/dev/null || true)
    if [[ -n "$proxy_ca" ]]; then
        system_bundle=""
        for candidate in \
            /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem \
            /etc/pki/tls/certs/ca-bundle.crt \
            /etc/ssl/certs/ca-certificates.crt; do
            if [[ -f "$candidate" ]]; then
                system_bundle="$candidate"
                break
            fi
        done
        # Atomic write: clawx.container and service-gator.container both run
        # this script as ExecStartPre and systemd may start them in parallel,
        # so a concurrent reader could otherwise observe a half-written
        # bundle and fail the TLS handshake. mktemp + mv eliminates the
        # window; the trap cleans up if cat/printf fails before the rename.
        tmp_bundle=$(mktemp "$merged_bundle.XXXXXX")
        trap 'rm -f "$tmp_bundle"' EXIT
        if [[ -n "$system_bundle" ]]; then
            { cat "$system_bundle"; printf '\n%s\n' "$proxy_ca"; } > "$tmp_bundle"
        else
            printf '%s\n' "$proxy_ca" > "$tmp_bundle"
        fi
        mv -f "$tmp_bundle" "$merged_bundle"
        trap - EXIT
    fi
else
    rm -f "$merged_bundle"
fi

# Login to the container registry for pulling the clawx-runtime image.
# Registry is derived from the Image= line in the Quadlet unit so this works
# regardless of which registry the image was pushed to.
if podman secret inspect registry_password >/dev/null 2>&1; then
    _image_line=$(grep -m1 '^Image=' /etc/containers/systemd/users/1000/clawx.container 2>/dev/null || true)
    if [[ -n "$_image_line" ]]; then
        _registry="${_image_line#Image=}"
        _registry="${_registry%%/*}"
        _user=$(podman secret inspect registry_user --showsecret --format '{{.SecretData}}' 2>/dev/null || true)
        _pass=$(podman secret inspect registry_password --showsecret --format '{{.SecretData}}' 2>/dev/null || true)
        if [[ -n "$_pass" ]]; then
            if ! printf '%s\n' "$_pass" | podman login "$_registry" \
                --username "${_user:-clawx}" \
                --password-stdin 2>&1; then
                echo "bootstrap-clawx: registry login to $_registry failed; image pull may fail if not cached" >&2
            fi
        fi
    fi
fi

# No explicit `podman rm` here: the Quadlet-generated clawx.service runs
# `podman run --name clawx --replace`, which already recreates the
# container fresh. An explicit rm would also be wrong — this script is a
# shared ExecStartPre of BOTH clawx.service and service-gator.service (so
# the merged CA bundle is built regardless of start order), and removing
# the clawx container from service-gator's pre-hook bounced clawx on
# every service-gator (re)start.
