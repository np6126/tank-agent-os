#!/usr/bin/env bash
set -euo pipefail

# Generates the per-container Quadlet drop-ins that inject podman secrets,
# egress-proxy settings and CA bundles from the operator's agent.env.
#
# Structured so the pure helpers (provider_family, no_proxy_for, the
# secret-dedup logic) can be sourced and unit-tested without podman or a
# clawx user: tools/unit-tests.sh sources this file; the main-guard at the
# bottom means sourcing defines the functions but runs nothing.

# All container names on the clawx-isolated bridge. Each container's
# NO_PROXY is derived from this list (minus self) plus loopback, so adding a
# new bridge peer means editing exactly one place.
bridge_hosts="clawx service-gator mcp-searxng searxng docs-mcp llm-wiki"

secret_exists() {
  podman secret inspect "$1" >/dev/null 2>&1
}

load_config() {
  if [[ -f "$config_file" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$config_file"
    set +a
  fi
}

provider_family() {
  case "${AGENT_PROVIDER:-}" in
    ollama|lmstudio|openrouter|openai|custom-openai-compatible)
      printf 'openai'
      ;;
    anthropic|custom-anthropic-compatible)
      printf 'anthropic'
      ;;
    *)
      printf 'unknown'
      ;;
  esac
}

no_proxy_for() {
  local self="$1" h out=""
  for h in $bridge_hosts; do
    [ "$h" = "$self" ] && continue
    out="${out}${out:+,}${h}"
  done
  printf '%s,127.0.0.1,::1,localhost' "$out"
}

add_clawx_secret() {
  local name="$1"
  local env="$2"
  if secret_exists "$name"; then
    if [[ "$clawx_secret_targets" == *" $env "* ]]; then
      return
    fi
    clawx_secret_lines+=("Secret=${name},type=env,target=${env}")
    clawx_secret_targets+="$env "
  fi
}

add_service_gator_secret() {
  local name="$1"
  if secret_exists "$name"; then
    service_gator_secret_lines+=("Secret=${name}")
  fi
}

# Append the egress-proxy lines for one container drop-in: HTTP_PROXY /
# HTTPS_PROXY (as podman secrets) and NO_PROXY into the [Container] section,
# and the same set into [Service] so image pulls by the podman process also
# route through the proxy and are not blocked by nftables. $1/$2 name the
# target arrays (by nameref); $3 is the container's NO_PROXY value; the proxy
# URL comes from the cached $proxy_url.
emit_proxy_env() {
  local -n _container_lines="$1"
  local -n _service_lines="$2"
  local no_proxy="$3"
  _container_lines+=("Secret=proxy_url,type=env,target=HTTP_PROXY")
  _container_lines+=("Secret=proxy_url,type=env,target=HTTPS_PROXY")
  _container_lines+=("Environment=NO_PROXY=${no_proxy}")
  _service_lines+=("Environment=HTTP_PROXY=${proxy_url}")
  _service_lines+=("Environment=HTTPS_PROXY=${proxy_url}")
  _service_lines+=("Environment=NO_PROXY=${no_proxy}")
}

main() {
  if [[ "$(id -un)" != "clawx" ]]; then
    echo "Run as the clawx user: sudo -iu clawx -- /usr/libexec/tank-os/sync-podman-secrets" >&2
    exit 1
  fi

  quadlet_dropin_dir="$HOME/.config/containers/systemd/clawx.container.d"
  quadlet_dropin="$quadlet_dropin_dir/10-secrets.conf"
  service_gator_dropin_dir="$HOME/.config/containers/systemd/service-gator.container.d"
  service_gator_dropin="$service_gator_dropin_dir/10-secrets.conf"
  searxng_dropin_dir="$HOME/.config/containers/systemd/searxng.container.d"
  searxng_dropin="$searxng_dropin_dir/10-secrets.conf"
  docs_mcp_dropin_dir="$HOME/.config/containers/systemd/docs-mcp.container.d"
  docs_mcp_dropin="$docs_mcp_dropin_dir/10-secrets.conf"
  llm_wiki_dropin_dir="$HOME/.config/containers/systemd/llm-wiki.container.d"
  llm_wiki_dropin="$llm_wiki_dropin_dir/10-secrets.conf"
  config_file="${AGENT_CONFIG:-$HOME/.clawx/agent.env}"

  mkdir -p "$quadlet_dropin_dir" "$service_gator_dropin_dir" "$searxng_dropin_dir" "$docs_mcp_dropin_dir" "$llm_wiki_dropin_dir" "$HOME/.clawx"
  load_config

  clawx_secret_lines=()
  clawx_extra_lines=()
  clawx_service_lines=()
  clawx_secret_targets=" "

  case "$(provider_family)" in
    openai)
      add_clawx_secret "agent_api_key" "OPENAI_API_KEY"
      add_clawx_secret "model_endpoint_api_key" "OPENAI_API_KEY"
      ;;
    anthropic)
      add_clawx_secret "agent_api_key" "ANTHROPIC_API_KEY"
      add_clawx_secret "model_endpoint_api_key" "ANTHROPIC_API_KEY"
      ;;
  esac

  add_clawx_secret "agent_api_key" "AGENT_API_KEY"
  add_clawx_secret "openai_api_key" "OPENAI_API_KEY"
  add_clawx_secret "anthropic_api_key" "ANTHROPIC_API_KEY"
  # Claude Code subscription auth (Pro/Max/Team/Enterprise): a long-lived
  # OAuth token from `claude setup-token`, used instead of an API key. Inert
  # for claw/opencode — the secret is simply absent on those deployments.
  add_clawx_secret "claude_code_oauth_token" "CLAUDE_CODE_OAUTH_TOKEN"
  add_clawx_secret "openrouter_api_key" "OPENAI_API_KEY"
  add_clawx_secret "model_endpoint_api_key" "MODEL_ENDPOINT_API_KEY"

  # Egress proxy secrets: inject HTTP_PROXY / HTTPS_PROXY and CA cert into clawx container.
  # /etc/clawx/proxy.env must be written separately (root-owned) so that
  # clawx-nftables.service can resolve the proxy host for nftables rules — see first-boot.md.
  clawx_no_proxy="$(no_proxy_for clawx)"
  service_gator_no_proxy="$(no_proxy_for service-gator)"
  searxng_no_proxy="$(no_proxy_for searxng)"
  docs_mcp_no_proxy="$(no_proxy_for docs-mcp)"
  llm_wiki_no_proxy="$(no_proxy_for llm-wiki)"

  # Fetch the egress-proxy secrets once — the proxy URL value and the two
  # presence flags below are reused by every per-container drop-in.
  proxy_url=""
  proxy_url_present=0
  proxy_ca_present=0
  if secret_exists "proxy_url"; then
    proxy_url_present=1
    proxy_url=$(podman secret inspect proxy_url --showsecret --format '{{.SecretData}}' 2>/dev/null || true)
  fi
  if secret_exists "proxy_ca_cert"; then
    proxy_ca_present=1
  fi

  if (( proxy_url_present )); then
    emit_proxy_env clawx_extra_lines clawx_service_lines "$clawx_no_proxy"
  fi
  if (( proxy_ca_present )); then
    clawx_secret_lines+=("Secret=proxy_ca_cert")
    # Mount the merged CA bundle (built by bootstrap-clawx = system CAs + proxy CA)
    # over every CA bundle path the container's runtimes consult:
    #   - /etc/pki/tls/certs/ca-bundle.crt   — OpenSSL default on Fedora/RHEL
    #   - /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem — rustls-native-certs
    #     and the symlink target of /etc/ssl/certs/ca-certificates.crt
    # NODE_EXTRA_CA_CERTS adds the proxy cert on top of Node.js's own built-in bundle.
    # SSL_CERT_FILE and REQUESTS_CA_BUNDLE cover OpenSSL programs and Python requests.
    # SELinux: %h/.clawx/ca-bundle.crt is shared by clawx, service-gator and
    # searxng. Every container that receives this :Z mount MUST pin
    # SecurityLabelLevel=s0:c200,c500 in its base .container file — otherwise
    # its :Z relabel steals the file's MCS categories from the others
    # (EACCES). CI guard: tools/check-selinux-mcs.sh.
    clawx_extra_lines+=("Volume=%h/.clawx/ca-bundle.crt:/etc/pki/tls/certs/ca-bundle.crt:ro,Z")
    clawx_extra_lines+=("Volume=%h/.clawx/ca-bundle.crt:/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem:ro,Z")
    clawx_extra_lines+=("Environment=NODE_EXTRA_CA_CERTS=/run/secrets/proxy_ca_cert")
    clawx_extra_lines+=("Environment=SSL_CERT_FILE=/etc/pki/tls/certs/ca-bundle.crt")
    clawx_extra_lines+=("Environment=REQUESTS_CA_BUNDLE=/etc/pki/tls/certs/ca-bundle.crt")
  fi

  {
    printf '[Container]\n'
    if ((${#clawx_secret_lines[@]} > 0)); then
      printf '%s\n' "${clawx_secret_lines[@]}"
    fi
    if ((${#clawx_extra_lines[@]} > 0)); then
      printf '%s\n' "${clawx_extra_lines[@]}"
    fi
    if ((${#clawx_service_lines[@]} > 0)); then
      printf '\n[Service]\n'
      printf '%s\n' "${clawx_service_lines[@]}"
    fi
  } >"$quadlet_dropin"

  service_gator_secret_lines=()
  service_gator_extra_lines=()
  service_gator_service_lines=()

  add_service_gator_secret "gh_token"
  add_service_gator_secret "gitlab_token"
  add_service_gator_secret "forgejo_token"
  add_service_gator_secret "jira_api_token"

  if (( proxy_url_present )); then
    emit_proxy_env service_gator_extra_lines service_gator_service_lines "$service_gator_no_proxy"
  fi
  if (( proxy_ca_present )); then
    # service-gator is Rust (reqwest with native-tls/rustls). Mount the merged
    # CA bundle over both the OpenSSL bundle path and the rustls-native pem
    # path so either TLS backend trusts the proxy's MITM cert.
    # Shared :Z mount — service-gator.container must pin SecurityLabelLevel
    # (see the clawx block above; tools/check-selinux-mcs.sh enforces it).
    service_gator_extra_lines+=("Volume=%h/.clawx/ca-bundle.crt:/etc/pki/tls/certs/ca-bundle.crt:ro,Z")
    service_gator_extra_lines+=("Volume=%h/.clawx/ca-bundle.crt:/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem:ro,Z")
    service_gator_extra_lines+=("Environment=SSL_CERT_FILE=/etc/pki/tls/certs/ca-bundle.crt")
  fi

  {
    printf '[Container]\n'
    if ((${#service_gator_secret_lines[@]} > 0)); then
      printf '%s\n' "${service_gator_secret_lines[@]}"
    fi
    if ((${#service_gator_extra_lines[@]} > 0)); then
      printf '%s\n' "${service_gator_extra_lines[@]}"
    fi
    if ((${#service_gator_service_lines[@]} > 0)); then
      printf '\n[Service]\n'
      printf '%s\n' "${service_gator_service_lines[@]}"
    fi
  } >"$service_gator_dropin"

  # SearXNG drop-in: route its upstream-engine HTTP traffic through the same
  # egress proxy as clawx. The container does not need any API-key secrets;
  # it only needs HTTP_PROXY, HTTPS_PROXY, NO_PROXY and the merged CA bundle.
  # Has no effect until the operator enables searxng.service.
  searxng_extra_lines=()
  searxng_service_lines=()
  if (( proxy_url_present )); then
    emit_proxy_env searxng_extra_lines searxng_service_lines "$searxng_no_proxy"
  fi
  if (( proxy_ca_present )); then
    # SearXNG is Python (requests/httpx) — REQUESTS_CA_BUNDLE + SSL_CERT_FILE
    # plus the bundle mounted over the system CA path is enough.
    # Shared :Z mount — searxng.container must pin SecurityLabelLevel
    # (see the clawx block above; tools/check-selinux-mcs.sh enforces it).
    searxng_extra_lines+=("Volume=%h/.clawx/ca-bundle.crt:/etc/ssl/certs/ca-certificates.crt:ro,Z")
    searxng_extra_lines+=("Environment=REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt")
    searxng_extra_lines+=("Environment=SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt")
  fi

  {
    printf '[Container]\n'
    if ((${#searxng_extra_lines[@]} > 0)); then
      printf '%s\n' "${searxng_extra_lines[@]}"
    fi
    if ((${#searxng_service_lines[@]} > 0)); then
      printf '\n[Service]\n'
      printf '%s\n' "${searxng_service_lines[@]}"
    fi
  } >"$searxng_dropin"

  # docs-mcp drop-in: same proxy + CA-bundle plumbing as searxng. docs-mcp's
  # scraper crawls upstream documentation hosts and consults Node.js's HTTPS
  # stack, so NODE_EXTRA_CA_CERTS is the relevant trust-anchor knob. Has no
  # effect until the operator enables docs-mcp.service.
  docs_mcp_extra_lines=()
  docs_mcp_service_lines=()
  if (( proxy_url_present )); then
    emit_proxy_env docs_mcp_extra_lines docs_mcp_service_lines "$docs_mcp_no_proxy"
  fi
  if (( proxy_ca_present )); then
    docs_mcp_extra_lines+=("Secret=proxy_ca_cert")
    docs_mcp_extra_lines+=("Environment=NODE_EXTRA_CA_CERTS=/run/secrets/proxy_ca_cert")
    # Chromium (Playwright headless for JS-heavy doc pages) reads its own
    # NSS user DB at $HOME/.pki/nssdb and ignores NODE_EXTRA_CA_CERTS / the
    # system OpenSSL bundle. The upstream docs-mcp image carries no
    # writable trust path and no certutil, so we build the NSS DB on the
    # host (bootstrap-docs-mcp-nssdb, using nss-tools) and mount it
    # read-only into the container. Without this, every Chromium TLS
    # handshake — including its built-in safe-browsing / component-update
    # probes — fails against the egress MITM proxy and floods the leash
    # audit log with handshake errors.
    docs_mcp_extra_lines+=("Volume=%h/.clawx/docs-mcp-nssdb:/home/node/.pki/nssdb:ro,Z")
    docs_mcp_service_lines+=("ExecStartPre=/usr/libexec/tank-os/bootstrap-docs-mcp-nssdb")
  fi

  {
    printf '[Container]\n'
    if ((${#docs_mcp_extra_lines[@]} > 0)); then
      printf '%s\n' "${docs_mcp_extra_lines[@]}"
    fi
    if ((${#docs_mcp_service_lines[@]} > 0)); then
      printf '\n[Service]\n'
      printf '%s\n' "${docs_mcp_service_lines[@]}"
    fi
  } >"$docs_mcp_dropin"

  # llm-wiki drop-in: the git-backed wiki MCP server. Unlike the other
  # MCPs it needs operator config — the Gitea base URL, the service-
  # account name, and the per-VM RW/READONLY wiki lists — all sourced
  # from agent.env. The Gitea API token is a podman secret
  # (llm_wiki_token) injected as env, never written to agent.env or the
  # image. The drop-in is only populated when AGENT_LLM_WIKI_URL is set;
  # until then llm-wiki.service has nothing to start with and the
  # operator has not opted in. Has no effect until the operator enables
  # llm-wiki.service.
  llm_wiki_secret_lines=()
  llm_wiki_extra_lines=()
  llm_wiki_service_lines=()

  if [ -n "${AGENT_LLM_WIKI_URL:-}" ]; then
    llm_wiki_extra_lines+=("Environment=AGENT_LLM_WIKI_URL=${AGENT_LLM_WIKI_URL}")
    llm_wiki_extra_lines+=("Environment=AGENT_LLM_WIKI_USER=${AGENT_LLM_WIKI_USER:-}")
    llm_wiki_extra_lines+=("Environment=AGENT_LLM_WIKI_ORG=${AGENT_LLM_WIKI_ORG:-}")
    llm_wiki_extra_lines+=("Environment=AGENT_LLM_WIKIS_RW=${AGENT_LLM_WIKIS_RW:-}")
    llm_wiki_extra_lines+=("Environment=AGENT_LLM_WIKIS_READONLY=${AGENT_LLM_WIKIS_READONLY:-}")
    # Optional: how long a read may reuse the working tree before the
    # server pulls again (seconds). Unset → the server's default (30).
    if [ -n "${MCP_LLM_WIKI_READ_TTL:-}" ]; then
      llm_wiki_extra_lines+=("Environment=MCP_LLM_WIKI_READ_TTL=${MCP_LLM_WIKI_READ_TTL}")
    fi
  fi

  if secret_exists "llm_wiki_token"; then
    llm_wiki_secret_lines+=("Secret=llm_wiki_token,type=env,target=AGENT_LLM_WIKI_TOKEN")
  fi

  if (( proxy_url_present )); then
    emit_proxy_env llm_wiki_extra_lines llm_wiki_service_lines "$llm_wiki_no_proxy"
  fi
  if (( proxy_ca_present )); then
    # llm-wiki's only egress is git to Gitea, and that traffic is MITM'd
    # by the egress proxy — so the single CA git must trust is the proxy
    # CA. Deliver it as a podman secret (readable by the container
    # regardless of host file mode or SELinux MCS label) and point git
    # at it. Same mechanism docs-mcp uses for Node's NODE_EXTRA_CA_CERTS;
    # avoids the ~/.clawx/ca-bundle.crt file, which is 0600 clawx-owned
    # and carries the clawx container's MCS label.
    llm_wiki_extra_lines+=("Secret=proxy_ca_cert")
    llm_wiki_extra_lines+=("Environment=GIT_SSL_CAINFO=/run/secrets/proxy_ca_cert")
  fi

  {
    printf '[Container]\n'
    if ((${#llm_wiki_secret_lines[@]} > 0)); then
      printf '%s\n' "${llm_wiki_secret_lines[@]}"
    fi
    if ((${#llm_wiki_extra_lines[@]} > 0)); then
      printf '%s\n' "${llm_wiki_extra_lines[@]}"
    fi
    if ((${#llm_wiki_service_lines[@]} > 0)); then
      printf '\n[Service]\n'
      printf '%s\n' "${llm_wiki_service_lines[@]}"
    fi
  } >"$llm_wiki_dropin"

  systemctl --user daemon-reload

  cat <<EOF
Wrote:
  $quadlet_dropin
  $service_gator_dropin
  $searxng_dropin
  $docs_mcp_dropin
  $llm_wiki_dropin

Detected claw-code secrets: ${#clawx_secret_lines[@]}
Detected claw-code extra lines: ${#clawx_extra_lines[@]}
Detected service-gator secrets: ${#service_gator_secret_lines[@]}
Detected service-gator proxy lines: ${#service_gator_extra_lines[@]}
Detected searxng proxy lines: ${#searxng_extra_lines[@]}
Detected docs-mcp proxy lines: ${#docs_mcp_extra_lines[@]}
Detected llm-wiki secrets: ${#llm_wiki_secret_lines[@]}
Detected llm-wiki extra lines: ${#llm_wiki_extra_lines[@]}

Restart services when ready:
  systemctl --user restart clawx.service
  systemctl --user restart service-gator.service
  systemctl --user restart searxng.service mcp-searxng.service  # if enabled
  systemctl --user restart docs-mcp.service                     # if enabled
  systemctl --user restart llm-wiki.service                     # if enabled
EOF
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
