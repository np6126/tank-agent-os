#!/usr/bin/env bash
set -euo pipefail

# clawx egress isolation — generates and loads the nftables ruleset that
# confines every user-1000 container to the egress proxy.
#
# Structured so the pure helpers (proxy-URL parsing, ruleset generation)
# can be sourced and unit-tested without root, nft or DNS:
#   tools/unit-tests.sh sources this file; the main-guard at the bottom
#   means sourcing defines the functions but runs nothing.

CLAWX_UID="${CLAWX_UID:-1000}"
CLAWX_PROXY_URL="${CLAWX_PROXY_URL:-}"
CLAWX_PROXY_PORT="${CLAWX_PROXY_PORT:-}"
CLAWX_USER="${CLAWX_USER:-clawx}"
CA_ANCHOR="/etc/pki/ca-trust/source/anchors/clawx-proxy-ca.pem"

install_proxy_ca() {
    local cert
    cert=$(runuser -u "$CLAWX_USER" -- \
        /usr/bin/podman secret inspect proxy_ca_cert \
        --showsecret --format '{{.SecretData}}' 2>/dev/null || true)
    if [[ -n "$cert" ]]; then
        # Skip the write + trust-store rebuild when the anchor is already
        # current. update-ca-trust extract rebuilds the whole trust store and
        # this runs on every clawx-nftables.service (re)start.
        if [[ -f "$CA_ANCHOR" && "$(cat "$CA_ANCHOR")" == "$cert" ]]; then
            return 0
        fi
        printf '%s\n' "$cert" > "$CA_ANCHOR"
        update-ca-trust extract
        echo "clawx-nftables: proxy CA cert installed into system trust store"
    elif [[ -f "$CA_ANCHOR" ]]; then
        rm -f "$CA_ANCHOR"
        update-ca-trust extract
        echo "clawx-nftables: proxy CA cert removed from system trust store"
    fi
}

# Host portion of a proxy URL: strip the scheme, then everything from the
# first ':' or '/'. Pure — no nft/DNS needed, so it is unit-testable.
parse_proxy_host() {
    printf '%s' "$1" | sed 's|^[a-z]*://||;s|[:/].*||'
}

# Port of a proxy URL. An explicit override ($2, from CLAWX_PROXY_PORT)
# wins; otherwise parse ':<port>' out of the URL; otherwise fall back to
# 8080. Pure — unit-testable.
parse_proxy_port() {
    local url="$1" explicit="${2:-}" port
    if [[ -n "$explicit" ]]; then
        printf '%s' "$explicit"
        return 0
    fi
    port=$(printf '%s' "$url" | sed -n 's|^[a-z]*://[^:]*:\([0-9]*\).*|\1|p')
    printf '%s' "${port:-8080}"
}

# Emit the nftables ruleset on stdout. Pure — every input is an argument so
# it can be unit-tested without root or a live proxy.
#   $1 = clawx UID
#   $2 = proxy port   (empty => deny-all baseline; no proxy configured)
#   $3 = IPv4 address list for the proxy set (comma-separated, may be empty)
#   $4 = IPv6 address list for the proxy set (comma-separated, may be empty)
generate_ruleset() {
    local uid="$1" port="$2" v4="$3" v6="$4"

    if [[ -z "$port" ]]; then
        # No proxy configured: deny-all baseline for the clawx UID.
        cat <<NFTEOF
table inet clawx-isolation {
    chain output {
        type filter hook output priority filter; policy accept;
        meta skuid != ${uid} return
        ct state established,related accept
        oif "lo" accept
        reject with icmp type host-prohibited
    }
}
NFTEOF
        return 0
    fi

    printf 'table inet clawx-isolation {\n'

    if [[ -n "$v4" ]]; then
        cat <<NFTEOF
    set proxy_v4 {
        type ipv4_addr
        flags interval
        elements = { ${v4} }
    }
NFTEOF
    fi

    if [[ -n "$v6" ]]; then
        cat <<NFTEOF
    set proxy_v6 {
        type ipv6_addr
        flags interval
        elements = { ${v6} }
    }
NFTEOF
    fi

    cat <<NFTEOF
    chain output {
        type filter hook output priority filter; policy accept;

        # Apply the proxy gate only to the clawx user. All four user-1000
        # containers (clawx, service-gator, searxng, docs-mcp) share this
        # UID and must reach the public internet exclusively through the
        # egress proxy — that is what makes the audit log complete.
        meta skuid != ${uid} return

        # Allow responses to already-established connections
        ct state established,related accept

        # Allow loopback: bridge traffic between containers and local DNS
        oif "lo" accept
NFTEOF

    if [[ -n "$v4" ]]; then
        cat <<NFTEOF

        # Allow egress proxy (IPv4)
        ip daddr @proxy_v4 tcp dport ${port} accept
NFTEOF
    fi

    if [[ -n "$v6" ]]; then
        cat <<NFTEOF

        # Allow egress proxy (IPv6)
        ip6 daddr @proxy_v6 tcp dport ${port} accept
NFTEOF
    fi

    cat <<NFTEOF

        # Block all other outbound from clawx — agent must use the egress proxy
        reject with icmp type host-prohibited
    }
}
NFTEOF
}

main() {
    # Remove any existing table first
    nft delete table inet clawx-isolation 2>/dev/null || true

    if [[ -z "$CLAWX_PROXY_URL" ]]; then
        # No proxy configured: install deny-all baseline for the clawx UID.
        # service-gator runs under the same UID and is subject to the same
        # rule — its outbound API calls go through the egress proxy now
        # (audit path), not direct. Without a proxy configured, nothing on
        # this UID has egress.
        generate_ruleset "$CLAWX_UID" "" "" "" | nft -f -
        echo "clawx-nftables: deny-all active for UID ${CLAWX_UID} (no proxy configured)"
        install_proxy_ca
        return 0
    fi

    # Proxy configured: full isolation with proxy allowance.
    local proxy_host proxy_port
    proxy_host=$(parse_proxy_host "$CLAWX_PROXY_URL")
    if [[ -z "$proxy_host" ]]; then
        echo "clawx-nftables: could not parse proxy host from CLAWX_PROXY_URL='$CLAWX_PROXY_URL'" >&2
        exit 1
    fi
    proxy_port=$(parse_proxy_port "$CLAWX_PROXY_URL" "$CLAWX_PROXY_PORT")

    # Resolve proxy hostname to addresses
    local -a proxy_v4 proxy_v6
    mapfile -t proxy_v4 < <(getent ahostsv4 "$proxy_host" 2>/dev/null | awk '{print $1}' | sort -u || true)
    mapfile -t proxy_v6 < <(getent ahostsv6 "$proxy_host" 2>/dev/null | awk '{print $1}' | sort -u || true)

    if [[ ${#proxy_v4[@]} -eq 0 && ${#proxy_v6[@]} -eq 0 ]]; then
        echo "clawx-nftables: DNS resolution failed for proxy host '$proxy_host'" >&2
        exit 1
    fi

    # Build comma-separated address lists for nftables sets
    local v4_elements="" v6_elements=""
    if [[ ${#proxy_v4[@]} -gt 0 ]]; then
        v4_elements=$(printf '%s, ' "${proxy_v4[@]}"); v4_elements="${v4_elements%, }"
    fi
    if [[ ${#proxy_v6[@]} -gt 0 ]]; then
        v6_elements=$(printf '%s, ' "${proxy_v6[@]}"); v6_elements="${v6_elements%, }"
    fi

    generate_ruleset "$CLAWX_UID" "$proxy_port" "$v4_elements" "$v6_elements" | nft -f -

    echo "clawx-nftables: isolation active (proxy ${proxy_host}:${proxy_port})"
    install_proxy_ca
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
