#!/usr/bin/env bash
set -euo pipefail

CLAWX_UID="${CLAWX_UID:-1000}"
CLAWX_PROXY_URL="${CLAWX_PROXY_URL:-}"
CLAWX_PROXY_PORT="${CLAWX_PROXY_PORT:-}"
CLAWX_USER="${CLAWX_USER:-clawx}"
CA_ANCHOR="/etc/pki/ca-trust/source/anchors/clawx-proxy-ca.pem"

install_proxy_ca() {
    local cert
    cert=$(runuser -u "$CLAWX_USER" -- \
        /usr/bin/podman secret inspect proxy_ca_cert \
        --showsecret --format '{{.SecretData}}' 2>/dev/null || true)
    if [[ -n "$cert" ]]; then
        printf '%s\n' "$cert" > "$CA_ANCHOR"
        update-ca-trust extract
        echo "clawx-nftables: proxy CA cert installed into system trust store"
    elif [[ -f "$CA_ANCHOR" ]]; then
        rm -f "$CA_ANCHOR"
        update-ca-trust extract
        echo "clawx-nftables: proxy CA cert removed from system trust store"
    fi
}

# Remove any existing table first
nft delete table inet clawx-isolation 2>/dev/null || true

if [[ -z "$CLAWX_PROXY_URL" ]]; then
    # No proxy configured: install deny-all baseline for the clawx UID.
    # service-gator runs under the same UID and is subject to the same rule —
    # its outbound API calls go through the egress proxy now (audit path),
    # not direct. Without a proxy configured, nothing on this UID has egress.
    nft -f - <<NFTEOF
table inet clawx-isolation {
    chain output {
        type filter hook output priority filter; policy accept;
        meta skuid != ${CLAWX_UID} return
        ct state established,related accept
        oif "lo" accept
        reject with icmp type host-prohibited
    }
}
NFTEOF
    echo "clawx-nftables: deny-all active for UID ${CLAWX_UID} (no proxy configured)"
    install_proxy_ca
    exit 0
fi

# Proxy configured: full isolation with proxy allowance.

# Parse host and port from proxy URL
PROXY_HOST=$(printf '%s' "$CLAWX_PROXY_URL" | sed 's|^[a-z]*://||;s|[:/].*||')
if [[ -z "$CLAWX_PROXY_PORT" ]]; then
    CLAWX_PROXY_PORT=$(printf '%s' "$CLAWX_PROXY_URL" | sed -n 's|^[a-z]*://[^:]*:\([0-9]*\).*|\1|p')
    CLAWX_PROXY_PORT="${CLAWX_PROXY_PORT:-8080}"
fi

if [[ -z "$PROXY_HOST" ]]; then
    echo "clawx-nftables: could not parse proxy host from CLAWX_PROXY_URL='$CLAWX_PROXY_URL'" >&2
    exit 1
fi

# Resolve proxy hostname to addresses
mapfile -t PROXY_V4 < <(getent ahostsv4 "$PROXY_HOST" 2>/dev/null | awk '{print $1}' | sort -u || true)
mapfile -t PROXY_V6 < <(getent ahostsv6 "$PROXY_HOST" 2>/dev/null | awk '{print $1}' | sort -u || true)

if [[ ${#PROXY_V4[@]} -eq 0 && ${#PROXY_V6[@]} -eq 0 ]]; then
    echo "clawx-nftables: DNS resolution failed for proxy host '$PROXY_HOST'" >&2
    exit 1
fi

# Build comma-separated address lists for nftables sets
v4_elements=""
if [[ ${#PROXY_V4[@]} -gt 0 ]]; then
    v4_elements=$(printf '%s, ' "${PROXY_V4[@]}"); v4_elements="${v4_elements%, }"
fi
v6_elements=""
if [[ ${#PROXY_V6[@]} -gt 0 ]]; then
    v6_elements=$(printf '%s, ' "${PROXY_V6[@]}"); v6_elements="${v6_elements%, }"
fi

# Generate ruleset
{
cat <<NFTEOF
table inet clawx-isolation {
NFTEOF

if [[ -n "$v4_elements" ]]; then
cat <<NFTEOF
    set proxy_v4 {
        type ipv4_addr
        flags interval
        elements = { ${v4_elements} }
    }
NFTEOF
fi

if [[ -n "$v6_elements" ]]; then
cat <<NFTEOF
    set proxy_v6 {
        type ipv6_addr
        flags interval
        elements = { ${v6_elements} }
    }
NFTEOF
fi

cat <<NFTEOF
    chain output {
        type filter hook output priority filter; policy accept;

        # Apply the proxy gate only to the clawx user. All four user-1000
        # containers (clawx, service-gator, searxng, docs-mcp) share this
        # UID and must reach the public internet exclusively through the
        # egress proxy — that is what makes the audit log complete.
        meta skuid != ${CLAWX_UID} return

        # Allow responses to already-established connections
        ct state established,related accept

        # Allow loopback: bridge traffic between containers and local DNS
        oif "lo" accept
NFTEOF

if [[ -n "$v4_elements" ]]; then
cat <<NFTEOF

        # Allow egress proxy (IPv4)
        ip daddr @proxy_v4 tcp dport ${CLAWX_PROXY_PORT} accept
NFTEOF
fi

if [[ -n "$v6_elements" ]]; then
cat <<NFTEOF

        # Allow egress proxy (IPv6)
        ip6 daddr @proxy_v6 tcp dport ${CLAWX_PROXY_PORT} accept
NFTEOF
fi

cat <<NFTEOF

        # Block all other outbound from clawx — agent must use the egress proxy
        reject with icmp type host-prohibited
    }
}
NFTEOF
} | nft -f -

echo "clawx-nftables: isolation active (proxy ${PROXY_HOST}:${CLAWX_PROXY_PORT})"

install_proxy_ca
