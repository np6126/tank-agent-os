{
  "scopes": {
    "gh": {
      "repos": {
        "owner/repo": {
          "read": true,
          "push-new-branch": false,
          "create-draft": false,
          "pending-review": false,
          "write": false,
          "require-fork": false
        }
      }
    },

    "gitlab": {
      "projects": {
        "group/project": {
          "read": true,
          "push-new-branch": false,
          "create-draft": false,
          "approve": false,
          "write": false,
          "require-fork": false
        }
      }
    },

    "forgejo": [
      {
        "host": "codeberg.org",
        "repos": {
          "owner/repo": {
            "read": true,
            "push-new-branch": false,
            "create-draft": false,
            "pending-review": false,
            "write": false,
            "require-fork": false
          }
        }
      }
    ],

    "jira": {
      "global_read": false,
      "projects": {
        "PROJECT_KEY": {
          "read": true,
          "comment": false,
          "create": false,
          "write": false
        }
      },
      "issues": {
        "PROJECT_KEY-123": {
          "read": true,
          "comment": false,
          "write": false
        }
      }
    }
  }
}
