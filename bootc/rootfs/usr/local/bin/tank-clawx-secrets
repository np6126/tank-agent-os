#!/usr/bin/env bash
set -euo pipefail

if [[ "$(id -un)" == "clawx" ]]; then
  exec /usr/libexec/tank-os/sync-podman-secrets "$@"
fi

if ! command -v sudo >/dev/null 2>&1; then
  echo "Run as clawx, or install sudo so this wrapper can delegate to the clawx user." >&2
  exit 1
fi

exec sudo -iu clawx -- /usr/libexec/tank-os/sync-podman-secrets "$@"
